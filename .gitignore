## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Rider
.idea/
*.sln.iml

# User-specific files
*.user
*.userosscache
*.suo
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
*.dll
*.exe
*.pdb
*.cache
*.log

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Entity Framework
*.edmx.diagram

# Node (if frontend inside project)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VS Code (if used occasionally)
.vscode/

# OS files
.DS_Store
Thumbs.db

# Test results
TestResults/
*.trx

# Coverage
coverage/
*.coverage
*.coveragexml

# Publish output
publish/
*.publishproj

# NuGet
*.nupkg
# Uncomment if you don't want to commit packages
# packages/

# JetBrains Rider caches
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/dictionaries
.idea/shelf

# Resharper (sometimes used with Rider)
_ReSharper*/
*.DotSettings.user

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Backup files
*.bak
*.swp
*.orig

# Database files
*.mdf
*.ldf

# Local settings
appsettings.Development.json